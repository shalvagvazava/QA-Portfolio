		{
			"name": "API-02 GET Brands List",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Status code is 200\", function () {",
							"  pm.response.to.have.status(200);",
							"});",
							"",
							"pm.test(\"Brands list exists\", function () {",
							"  const body = pm.response.json();",
							"  pm.expect(body).to.have.property(\"brands\");",
							"  pm.expect(body.brands.length).to.be.above(0);",
							"});"
						],
						"type": "text/javascript",
						"packages": {}
					}
				}
			],
			"request": {
				"auth": {
					"type": "noauth"
				},
				"method": "GET",
				"header": [],
				"url": "{{baseUrl}}/api/brandsList"
			},
			"response": []
		},
		{
			"name": "API-03 POST Search Product (Valid)",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Status code is 200\", function () {",
							"  pm.response.to.have.status(200);",
							"});",
							"",
							"pm.test(\"Response contains products list\", function () {",
							"  const body = pm.response.json();",
							"  pm.expect(body).to.have.property(\"products\");",
							"});"
						],
						"type": "text/javascript",
						"packages": {}
					}
				}
